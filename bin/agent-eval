#!/usr/bin/env bash
# AgentEval-Lite CLI 启动器：定位 shaded jar 并透传参数。
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
JAR="$(ls -1 "$PROJECT_DIR"/target/agent-eval-lite-*-cli.jar 2>/dev/null | head -n 1 || true)"

if [ -z "$JAR" ]; then
  echo "未找到 CLI jar，请先构建: (cd \"$PROJECT_DIR\" && mvn -q -DskipTests package)" >&2
  exit 1
fi

exec java -jar "$JAR" "$@"
