{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenteval.local/schemas/submission.review.schema.json",
  "title": "评审任务提交",
  "type": "object",
  "required": ["submission_type", "deliverable", "sources", "confidence"],
  "properties": {
    "submission_type": { "const": "review" },
    "deliverable": {
      "type": "object",
      "required": ["type", "content"],
      "properties": {
        "type": { "enum": ["markdown", "json"] },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
